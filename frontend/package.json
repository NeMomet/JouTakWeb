{
  "name": "frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20.19"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint . --cache",
    "lint:fix": "eslint . --fix --cache",
    "format": "prettier . --check",
    "format:fix": "prettier . --write",
    "lint:styles": "stylelint \"**/*.{css,scss}\" --cache",
    "lint:styles:fix": "stylelint \"**/*.{css,scss}\" --fix --cache",
    "test": "vitest",
    "test:run": "vitest run",
    "check": "npm run lint && npm run format && npm run lint:styles && npm run test:run && npm run build",
    "prepare": "node ./prepare-husky.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "@github/webauthn-json": "^2.1.1",
    "@gravity-ui/navigation": "^2.33.0",
    "@gravity-ui/uikit": "^6.43.0",
    "@openfeature/react-sdk": "^1.3.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/context-zone": "^2.7.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.215.0",
    "@opentelemetry/instrumentation": "^0.215.0",
    "@opentelemetry/instrumentation-document-load": "^0.60.0",
    "@opentelemetry/instrumentation-fetch": "^0.215.0",
    "@opentelemetry/instrumentation-xml-http-request": "^0.215.0",
    "@opentelemetry/resources": "^2.7.0",
    "@opentelemetry/sdk-trace-base": "^2.7.0",
    "@opentelemetry/sdk-trace-web": "^2.7.0",
    "axios": "^1.16.0",
    "bootstrap": "^5.3.3",
    "prop-types": "^15.8.1",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-bootstrap": "^2.10.9",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.17.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react-swc": "^3.5.0",
    "eslint": "^9.19.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.0.0",
