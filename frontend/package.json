    "jsdom": "26.1.0",
    "lint-staged": "^16.4.0",
    "msw": "^2.13.6",
    "prettier": "^3.5.0",
    "stylelint": "^16.14.1",
    "stylelint-config-standard": "^37.0.0",
    "vite": "^6.4.2",
    "vitest": "^4.1.5"
  }
