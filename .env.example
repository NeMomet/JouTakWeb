DJANGO_SETTINGS_MODULE=backend.settings.prod
DJANGO_SECRET_KEY=VERY_LONG_PASS_>80!TODO_CHANGE_ME!
# Optional Docker secret files (take precedence over plain env):
# DJANGO_SECRET_KEY_FILE=/run/secrets/django_secret_key
# DATABASE_URL_FILE=/run/secrets/database_url
DJANGO_TIME_ZONE=UTC

DJANGO_ALLOWED_HOSTS=joutak.ru,api.joutak.ru,admin.joutak.ru
DJANGO_ADMIN_HOSTS=admin.joutak.ru
DJANGO_API_HOSTS=api.joutak.ru
DJANGO_CSRF_TRUSTED_ORIGINS=https://joutak.ru,https://api.joutak.ru,https://admin.joutak.ru
CORS_ALLOWED_ORIGINS=https://joutak.ru

USE_X_FORWARDED_PROTO=true
SECURE_SSL_REDIRECT=true
SECURE_HSTS_SECONDS=31536000
SESSION_COOKIE_SAMESITE=None
CSRF_COOKIE_SAMESITE=None
SESSION_COOKIE_SECURE=true
CSRF_COOKIE_SECURE=true
SESSION_COOKIE_DOMAIN=.joutak.ru
CSRF_COOKIE_DOMAIN=.joutak.ru

# Frontend points to the dedicated public API/BFF host.
PUBLIC_API_URL=https://api.joutak.ru
FRONTEND_BASE_URL=https://joutak.ru
DJANGO_SITE_DOMAIN=joutak.ru
DJANGO_SITE_NAME=JouTak
# Optional image tags for docker-compose.images.yml
BACKEND_TAG=latest
FRONTEND_TAG=latest
# Optional published port for the frontend in docker-compose.images.yml.
# Backend порт наружу по умолчанию не публикуется: используйте Traefik
# (docker-compose.yml / stack.yml) или собственный override, если нужно
# выставить API наружу напрямую.
FRONTEND_PORT=8010
OTEL_SERVICE_NAME=joutak-backend
# Optional OTLP endpoint for backend traces, for example https://otel.example.com
OTEL_EXPORTER_OTLP_ENDPOINT=
# Optional direct traces endpoint override for backend, for example https://otel.example.com/v1/traces
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=
OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=
OTEL_METRICS_EXPORT_INTERVAL_MS=60000
# Optional frontend OTLP traces endpoint, must end with /v1/traces
FRONTEND_OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=
FRONTEND_OTEL_SERVICE_NAME=joutak-frontend

POSTGRES_DB=joutak
POSTGRES_USER=joutak
POSTGRES_PASSWORD=!TODO_CHANGE_ME!
DB_SSL_REQUIRED=false
DB_CONN_MAX_AGE=600

GUNICORN_WORKERS=3
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=60
GUNICORN_BIND=0.0.0.0:8000

JWT_ACCESS_MIN=15
JWT_REFRESH_DAYS=30
JWT_ROTATE_REFRESH=true
JWT_BLACKLIST_AFTER_ROTATION=true
AUTH_SESSION_RETENTION_DAYS=30
AUTH_TOKEN_RETENTION_DAYS=30
AVATAR_MAX_UPLOAD_BYTES=2097152
JWT_REFRESH_COOKIE_NAME=joutak_refresh
JWT_REFRESH_COOKIE_DOMAIN=
JWT_REFRESH_COOKIE_PATH=/api/auth/refresh
JWT_REFRESH_COOKIE_SECURE=true
JWT_REFRESH_COOKIE_SAMESITE=Lax

FF_PROFILE_PERSONALIZATION_UI=true
FF_PROFILE_PERSONALIZATION_INTERSTITIAL=true
FF_PROFILE_PERSONALIZATION_ENFORCE=false
# Enable this when Django sits behind a trusted reverse proxy.
ACCOUNT_TRUST_PROXY_HEADERS=true
# Example: ACCOUNT_TRUSTED_PROXY_CIDRS=172.18.0.0/16,10.0.0.0/8
ACCOUNT_TRUSTED_PROXY_CIDRS=
# Optional dedicated MFA encryption material. New encryptions use the first key.
MFA_ENCRYPTION_KEYS=

EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=noreply@example.com
EMAIL_HOST_PASSWORD=!TODO_CHANGE_ME!
EMAIL_USE_SSL=false
# EMAIL_USE_TLS=true
EMAIL_TIMEOUT=10
DEFAULT_FROM_EMAIL=noreply@example.com

#YANDEX_CLIENT_ID=
#YANDEX_SECRET=
SENTRY_TRACES=0.0
SENTRY_PROFILES=0.0
